{
  "name": "traklet",
  "version": "0.1.4",
  "description": "Drop-in issue tracking and test case management widget for any JavaScript application",
  "type": "module",
  "main": "dist/traklet.umd.js",
  "module": "dist/traklet.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/traklet.es.js",
      "require": "./dist/traklet.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./lit": {
      "import": "./dist/lit/index.js",
      "types": "./dist/lit/index.d.ts"
    }
  },
  "files": [
    "dist",
    ".traklet/settings.template.json",
    ".traklet/config.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rvegajr/traklet.git"
  },
  "bugs": {
    "url": "https://github.com/rvegajr/traklet/issues"
  },
  "homepage": "https://github.com/rvegajr/traklet#readme",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "vite --port 8888",
    "build": "tsc && vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "issue-tracking",
    "widget",
    "github-issues",
    "azure-devops",
    "web-component",
    "lit",
    "shadow-dom"
  ],
  "author": "Traklet Contributors",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lit": "^1.11.0",
    "jsdom": "^23.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "idb": "^8.0.0",
    "lit": "^3.1.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
