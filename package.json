{
  "name": "traklet",
  "version": "0.1.0-alpha.1",
  "description": "Backend-agnostic issue tracking widget for any JavaScript application",
  "type": "module",
  "main": "dist/traklet.umd.js",
  "module": "dist/traklet.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/traklet.es.js",
      "require": "./dist/traklet.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./lit": {
      "import": "./dist/lit/index.js",
      "types": "./dist/lit/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/traklet.git"
  },
  "bugs": {
    "url": "https://github.com/user/traklet/issues"
  },
  "homepage": "https://github.com/user/traklet#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "issue-tracking",
    "widget",
    "github-issues",
    "azure-devops",
    "web-component",
    "lit",
    "shadow-dom"
  ],
  "author": "Traklet Contributors",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lit": "^1.11.0",
    "jsdom": "^23.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "lit": "^3.1.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
